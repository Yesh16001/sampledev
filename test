echo "Your Name"


DOCKER PRACTICAL COMMANDS
1. Check Docker Version
docker --version
________________________________________
2. Build Docker Image
docker build -t demo-website .
________________________________________
3. Run Docker Container
docker run -d -p 8081:80 --name mywebsite demo-website
________________________________________
4. List Running Containers
docker ps
________________________________________
5. Stop Running Container
docker stop mywebsite
________________________________________
6. Verify Container Status
docker ps
________________________________________
7. Remove Container
docker rm -f mywebsite
________________________________________
8. Remove Docker Image
docker rmi demo-website



